<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX v4 installer for SynthEdit Community Modules.

  Build via CI (see .github/workflows/ci.yml), or locally:

    python3 .github/scripts/generate_wxs.py universal-bundles harvested.wxs
    wix build community_modules.wxs harvested.wxs ^
      -d Version=1.0.0 ^
      -arch x64 ^
      -o community_modules.msi

  Installs universal .sem/.gmpi bundles to:
    C:\Program Files\Common Files\SynthEdit\modules\Community\
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package
    Name="SynthEdit Community Modules"
    Manufacturer="SynthEdit Community"
    Version="$(var.Version)"
    UpgradeCode="6F8E2A4B-D312-4C89-B7F1-3A5D9E012C48"
    Scope="perMachine">

    <!-- Silently remove any older version before installing -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of SynthEdit Community Modules is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <Feature Id="ProductFeature" Title="Community Modules" Level="1">
      <ComponentGroupRef Id="ModuleFiles" />
    </Feature>

    <!--
      Setup wizard: Welcome -> install -> Finish.

      We base it on WixUI_InstallDir (which provides the standard dialog
      chrome) but reroute the navigation to skip BOTH the license-agreement
      page and the install-folder page: SynthEdit only finds modules in the
      fixed Common Files location below, so the folder must not be user-editable.
      WIXUI_INSTALLDIR is still required by the dialog set even though we never
      show its dialog.
    -->
    <ui:WixUI Id="WixUI_InstallDir" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLDIR" />
    <UI>
      <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="VerifyReadyDlg" Order="2" Condition="NOT Installed" />
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg" Order="2" Condition="NOT Installed" />
    </UI>

    <!--
      Install to: C:\Program Files\Common Files\SynthEdit\modules\Community\
      Use CommonFiles64Folder (the 64-bit Common Files = C:\Program Files\Common Files)
      so the x64 modules land where 64-bit SynthEdit/SynthEditCL scans. CommonFilesFolder
      (no "64") is the 32-bit property: it resolves to C:\Program Files (x86)\Common Files
      even in an x64 package, which is the wrong place and SynthEdit never looks there.
    -->
    <StandardDirectory Id="CommonFiles64Folder">
      <Directory Id="SECOMMONDIR" Name="SynthEdit">
        <Directory Id="MODULESDIR" Name="modules">
          <Directory Id="INSTALLDIR" Name="Community" />
        </Directory>
      </Directory>
    </StandardDirectory>

  </Package>

  <!--
    ModuleFiles ComponentGroup is generated at build time by:
      python3 .github/scripts/generate_wxs.py universal-bundles harvested.wxs
    harvested.wxs is then passed alongside this file to wix build.
  -->

</Wix>
