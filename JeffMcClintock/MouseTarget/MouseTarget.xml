<?xml version="1.0" encoding="UTF-8"?>
<PluginList>
	<Plugin id="SE SVG Image" name="SVG Image" category="Experimental/Sub-Controls/Conversion">
		<GUI>
			<Pin name="SVG File" datatype="string" isFilename="true" metadata="svg"/>
			<Pin name="Fill" datatype="blob" class="SE::Color"/>
			<Pin name="Stroke" datatype="blob" class="SE::Color"/>

			<Pin name="Intensity" datatype="float" default="-0.5" isMinimised="true"/>
			<Pin name="Visible" datatype="bool" default="1"/>
			<Pin name="HD" datatype="bool"/>
		</GUI>
	</Plugin>
	<Plugin id="SE Color Lag" name="Color Lag" category="Experimental/Sub-Controls/Conversion">
		<GUI>
			<Pin name="In" datatype="blob" class="SE::Color"/>
			<Pin name="Out" datatype="blob" class="SE::Color" direction="out"/>
		</GUI>
	</Plugin>
	<Plugin id="SE Floats to Color" name="Floats to Color" category="Experimental/Sub-Controls/Conversion">
		<GUI>
			<Pin name="R" datatype="float" default="1"/>
			<Pin name="G" datatype="float" default="1"/>
			<Pin name="B" datatype="float" default="1"/>
			<Pin name="A" datatype="float" default="1"/>
			<Pin name="Color" datatype="blob" direction="out"/>
		</GUI>
	</Plugin>
	<Plugin id="SE Hex to Color" name="Hex to Color" category="Experimental/Sub-Controls/Conversion">
		<GUI>
			<Pin name="Hex Color" datatype="string" default="ffff00"/>
			<Pin name="Color" datatype="blob" class="SE::Color" direction="out"/>
		</GUI>
	</Plugin>
	<Plugin id="SE Blob Switch" name="Blob Switch" category="Experimental/Sub-Controls">
		<GUI>
			<Pin name="Out" datatype="blob" direction="out"/>
			<Pin name="Select" datatype="int"/>
			<Pin name="In" datatype="blob" autoDuplicate="true" autoRename="true"/>
		</GUI>
	</Plugin>
	<Plugin id="SE Color Switch" name="Color Switch" category="Experimental/Sub-Controls">
		<GUI>
			<Pin name="Out" datatype="int64" direction="out"/>
			<Pin name="Select" datatype="int"/>
			<Pin name="In" datatype="int64" autoDuplicate="true" autoRename="true"/>
		</GUI>
	</Plugin>
	<Plugin id="SE Dumb Label" name="Label" category="Experimental/Sub-Controls">
		<GUI graphicsApi="GmpiGui">
			<Pin name="Text" datatype="string" default="&#x2660;"/> <!-- unicode char number 2660 (hex) -->
			<Pin name="Color" datatype="blob" class="SE::Color" default="4278190080" />
		</GUI>
	</Plugin>
	<Plugin id="SE Mouse Target" name="Mouse Target" category="Experimental/Sub-Controls">
		<GUI graphicsApi="GmpiGui">
			<Pin name="Show" datatype="bool" isMinimised="true"/>
			<Pin name="Hover" datatype="bool" direction="out"/>
			<Pin name="Left Click" datatype="bool" direction="out"/>
			<Pin name="Drag H" datatype="float" direction="out"/>
			<Pin name="Drag V" datatype="float" direction="out"/>
		</GUI>
	</Plugin>
	<Plugin id="SE MT2PMB" name="Mouse Target to PatchMem Bool" category="Experimental/Sub-Controls">
		<GUI graphicsApi="GmpiGui">
			<Pin name="Toggle" datatype="bool" isMinimised="true"/>
			<Pin name="Click" datatype="bool"/>
			<Pin name="Value" datatype="bool"/>
		</GUI>
	</Plugin>
	<Plugin id="SE MT2PMF" name="Mouse Target to PatchMem Float" category="Experimental/Sub-Controls">
		<GUI graphicsApi="GmpiGui">
			<Pin name="Drag" datatype="float"/>
			<Pin name="Animation Position" datatype="float"/>
		</GUI>
	</Plugin>
	<Plugin id="SE MathGui Multiply" name="Multiply (int)" category="Experimental/Sub-Controls">
		<GUI>
			<Pin name="Result" datatype="int" direction="out"/>
			<Pin name="In" datatype="int" autoDuplicate="true" />
		</GUI>
	</Plugin>
	<Plugin id="SE MathGui Add" name="Add (int)" category="Experimental/Sub-Controls">
		<GUI>
			<Pin name="Result" datatype="int" direction="out"/>
			<Pin name="In" datatype="int" autoDuplicate="true" />
		</GUI>
	</Plugin>
	<Plugin id="SE MathGui Bin2Int" name="Binary 2 Int" category="Experimental/Sub-Controls">
		<GUI>
			<Pin name="Result" datatype="int" direction="out"/>
			<Pin name="In" datatype="bool" autoDuplicate="true" />
		</GUI>
	</Plugin>
	<Plugin id="Image4" name="Image4" category="Experimental/Sub-Controls" >
		<GUI graphicsApi="GmpiGui">
			<Pin name="Filename" datatype="string" default="knob_sm" isFilename="true" metadata="bmp" />
			<Pin name="Animation Position" datatype="float" default="-1" />
			<Pin name="Frame" datatype="int" default="-1" />
			<Pin name="HD" datatype="bool" isMinimised="true"/>
		</GUI>
	</Plugin>
</PluginList>
